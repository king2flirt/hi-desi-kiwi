---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import Skills from '../components/Skills.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Umakant Chaudhari - Support, Systems & Soul">
  <Navigation />
  
  <main>
    <Hero />
    
    <Skills />
  </main>

</BaseLayout>

<style>
  /* Since we removed the Recent Posts section, 
     we don't need any extra styles here. 
     The styles for Hero and Skills live in their own files.
  */
  main {
    position: relative;
    z-index: 1;
  }
</style>