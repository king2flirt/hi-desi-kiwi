---
import BaseLayout from '../layouts/BaseLayout.astro';
import ThreeBackground from '../components/ThreeBackground.astro';
import Navigation from '../components/Navigation.astro';
---

<BaseLayout title="About - Darkness" description="About me and my work">
  <ThreeBackground />
  <Navigation />

  <main class="about-page">
    <div class="container">
      <h1 class="page-title shimmer-text">About Me</h1>

      <div class="content-grid">
        <section class="content-section intro-section">
          <h2>Hello, I'm Darkness</h2>
          <p>
            I'm a web developer and creative coder passionate about building immersive digital experiences.
            My work sits at the intersection of art and technology, where I explore the possibilities of
            modern web technologies to create visually striking, motion-rich interfaces.
          </p>
          <p>
            With a deep love for dark aesthetics and smooth animations, I specialize in crafting websites
            that aren't just functional—they're experiences that captivate and engage users from the moment
            they land on the page.
          </p>
        </section>

        <section class="content-section">
          <h2>What I Do</h2>
          <div class="what-i-do-grid">
            <div class="service-card">
              <div class="service-icon">🎨</div>
              <h3>Creative Development</h3>
              <p>Building unique web experiences with Three.js, WebGL, and advanced CSS animations.</p>
            </div>
            <div class="service-card">
              <div class="service-icon">⚡</div>
              <h3>Performance Optimization</h3>
              <p>Ensuring smooth 60fps animations and optimal loading times with modern tooling.</p>
            </div>
            <div class="service-card">
              <div class="service-icon">🌌</div>
              <h3>3D Graphics</h3>
              <p>Creating particle systems, geometric patterns, and interactive 3D elements for the web.</p>
            </div>
            <div class="service-card">
              <div class="service-icon">🎭</div>
              <h3>Dark UI Design</h3>
              <p>Designing beautiful dark-themed interfaces with carefully crafted color palettes.</p>
            </div>
          </div>
        </section>

        <section class="content-section">
          <h2>My Approach</h2>
          <p>
            I believe that motion is emotion. Every animation, every transition, every particle movement
            should have a purpose—to guide, to delight, or to immerse. I'm constantly pushing the boundaries
            of what's possible on the web, experimenting with new techniques and technologies.
          </p>
          <p>
            Whether it's a personal blog, a portfolio site, or a complex web application, I approach each
            project with the same goal: create something that stands out, performs well, and provides an
            unforgettable user experience.
          </p>
        </section>

        <section class="content-section cta-section">
          <h2>Let's Connect</h2>
          <p>Interested in working together or just want to chat about web animations and dark design?</p>
          <div class="contact-buttons">
            <a href="/projects" class="btn btn-primary">View My Work</a>
            <a href="/blog" class="btn btn-secondary">Read My Blog</a>
          </div>
        </section>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .about-page {
    min-height: 100vh;
    padding: 5rem 2rem;
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .page-title {
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 900;
    text-align: center;
    margin-bottom: 4rem;
    animation: fadeInDown 1s ease-out;
  }

  .content-grid {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .content-section {
    background: var(--color-bg-card);
    border: 1px solid rgba(168, 85, 247, 0.2);
    border-radius: 1rem;
    padding: 2.5rem;
    animation: fadeInUp 1s ease-out;
    animation-fill-mode: backwards;
  }

  .content-section:nth-child(1) { animation-delay: 0.1s; }
  .content-section:nth-child(2) { animation-delay: 0.2s; }
  .content-section:nth-child(3) { animation-delay: 0.3s; }
  .content-section:nth-child(4) { animation-delay: 0.4s; }

  .content-section h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, var(--color-accent-purple), var(--color-accent-pink));
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .content-section p {
    line-height: 1.8;
    color: var(--color-text-dim);
    margin-bottom: 1rem;
  }

  .intro-section p:last-of-type {
    margin-bottom: 0;
  }

  .what-i-do-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .service-card {
    padding: 1.5rem;
    background: rgba(168, 85, 247, 0.05);
    border-radius: 0.75rem;
    border: 1px solid rgba(168, 85, 247, 0.2);
    transition: all 0.3s ease;
  }

  .service-card:hover {
    background: rgba(168, 85, 247, 0.1);
    transform: translateY(-5px);
    border-color: var(--color-accent-purple);
  }

  .service-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .service-card h3 {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .service-card p {
    font-size: 0.9rem;
    color: var(--color-text-dim);
    margin: 0;
  }

  .cta-section {
    text-align: center;
  }

  .contact-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-block;
    padding: 1rem 2.5rem;
    font-size: 1.1rem;
    font-weight: 600;
    text-decoration: none;
    border: none;
    border-radius: 0.5rem;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--color-accent-purple), var(--color-accent-pink));
    color: white;
    box-shadow: 0 10px 30px rgba(168, 85, 247, 0.4);
  }

  .btn-primary:hover {
    transform: translateY(-3px) scale(1.05);
    box-shadow: 0 15px 40px rgba(168, 85, 247, 0.6);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-text);
    border: 2px solid var(--color-accent-purple);
  }

  .btn-secondary:hover {
    background: var(--color-accent-purple);
    transform: translateY(-3px);
    box-shadow: 0 10px 30px rgba(168, 85, 247, 0.4);
  }

  @keyframes fadeInDown {
    from {
      opacity: 0;
      transform: translateY(-30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
