---
// Navigation component - Focused on Socials & Consultation
const base = import.meta.env.BASE_URL;
---

<nav class="nav">
  <div class="nav-container">
    <div class="nav-links">
      <a href="https://desi.kiwi" target="_blank" class="nav-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
        <span>Blog</span>
      </a>

      <a href="https://www.linkedin.com/in/umakantsc/" target="_blank" class="nav-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
        <span>LinkedIn</span>
      </a>

      <a href="https://signal.me/#eu/ZcJGBvW_xGsHiWooxYWLhBUDrJrsQfVKlDxeiFrw-zMddYmjT0lF1I3Jo1GCDA7W" target="_blank" class="nav-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M12 18c-4.4 0-8-3.6-8-8s3.6-8 8-8 8 3.6 8 8c0 2.2-.9 4.2-2.3 5.7L12 22l-1.5-4h1.5z"></path></svg>
        <span>Signal</span>
      </a>

      <a href="https://www.instagram.com/umakantsc" target="_blank" class="nav-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
        <span>Instagram</span>
      </a>
    </div>

    <div class="nav-contact">
      <a href="https://wise.com/pay/r/UNZ8L6yTGF0FOhM" target="_blank" class="contact-pill">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
        <span>Book Consultation</span>
      </a>
    </div>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 1rem;
    left: 1rem;
    right: 1rem;
    z-index: 1000;
    padding: 0.6rem 1.25rem;
    background: rgba(15, 23, 42, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 1rem;
  }

  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.875rem;
    transition: all 0.2s ease;
  }

  .nav-link:hover {
    color: #fff;
  }

  .nav-link svg {
    opacity: 0.8;
    transition: transform 0.2s ease;
  }

  .nav-link:hover svg {
    transform: translateY(-1px);
    opacity: 1;
  }

  .contact-pill {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: #3b82f6; 
    color: white;
    padding: 0.5rem 1.25rem;
    border-radius: 2rem;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 600;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .contact-pill:hover {
    background: #2563eb;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
  }

  /* Hide text labels on smaller screens (Tablets/Phones) */
  @media (max-width: 1024px) {
    .nav-link span {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .nav-links {
      gap: 1.2rem; /* Tighten gap slightly for small screens */
    }
    
    /* Removed the :nth-child restriction so all icons show */
    .nav-link {
      display: flex !important; 
    }

    .contact-pill span {
        display: none; /* Icon only for Booking on mobile */
    }
    
    .contact-pill {
        padding: 0.6rem;
    }
  }
</style>