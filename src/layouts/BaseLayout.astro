---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import ThreeBackground from '../components/ThreeBackground.astro';

interface Props {
  title?: string;
  description?: string;
}

const base = import.meta.env.BASE_URL;

// Tagline: Grounded in Care. Powered by Linux. Guided by Soul
const {
  title = 'Umakant Chaudhari | Grounded in Care. Powered by Linux. Guided by Soul',
  description = 'Professional Healthcare & Disability Support, Linux HomeLab Enthusiast, and Spiritual Practitioner based in Christchurch, NZ.'
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    
    <link rel="icon" type="image/png" href={`${base}favicon.png`} />
    
    <meta name="generator" content={Astro.generator} />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
    
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <div class="cursor-follower"></div>
    <ThreeBackground />
    
    <div id="page-content">
      <slot />
    </div>

    <style is:global>
      #page-content {
        position: relative;
        z-index: 1;
      }

      /* Custom cursor styles */
      .cursor-follower {
        width: 20px;
        height: 20px;
        border: 2px solid #3b82f6; /* Your primary blue */
        border-radius: 50%;
        position: fixed;
        pointer-events: none;
        z-index: 9999;
        transition: width 0.2s ease, height 0.2s ease, background-color 0.2s ease;
        transform: translate(-50%, -50%);
        mix-blend-mode: difference;
        display: block;
      }

      .cursor-follower::before {
        content: '';
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 4px;
        height: 4px;
        background: #ec4899; /* Accent Pink */
        border-radius: 50%;
      }

      /* Disable custom cursor on mobile touch devices */
      @media (hover: none) {
        .cursor-follower {
          display: none;
        }
      }
    </style>

    <script>
      const initCursor = () => {
        const cursor = document.querySelector('.cursor-follower') as HTMLElement | null;
        if (!cursor) return;

        // Move cursor with mouse
        window.addEventListener('mousemove', (e) => {
          cursor.style.left = e.clientX + 'px';
          cursor.style.top = e.clientY + 'px';
        });

        // Hover expand effect for interactive elements
        const interactiveElements = document.querySelectorAll('a, button, .pillar-card, .contact-pill, .nav-link');
        interactiveElements.forEach((el) => {
          el.addEventListener('mouseenter', () => {
            cursor.style.width = '50px';
            cursor.style.height = '50px';
            cursor.style.backgroundColor = 'rgba(59, 130, 246, 0.15)';
          });
          el.addEventListener('mouseleave', () => {
            cursor.style.width = '20px';
            cursor.style.height = '20px';
            cursor.style.backgroundColor = 'transparent';
          });
        });
      };

      // Initialization for Astro View Transitions
      initCursor();
      document.addEventListener('astro:page-load', initCursor);
    </script>
  </body>
</html>